{
  "name": "confluence",
  "version": "1.0.4",
  "description": "Cross-platform desktop chat aggregator for YouTube, Twitch, and Kick",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --config vite.config.ts",
    "tauri:dev": "tauri dev",
    "build": "tsc --noEmit -p tsconfig.web.json && vite build --config vite.config.ts",
    "tauri:build": "tauri build --no-bundle",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "lint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint src/renderer src/shared --ext .ts,.tsx",
    "test": "vitest run"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-virtual": "^3.10.9",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "eslint": "^9.18.0",
    "immer": "^10.1.1",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.469.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "zustand": "^5.0.3"
  }
}
